---
import { listingStatusMeta, type Listing } from '../data/mockListings'
import { getListingHref } from '../data/siteRoutes'

type Props = {
  item: Listing
  variant?: 'home' | 'directory'
}

const { item, variant = 'directory' } = Astro.props
const isHome = variant === 'home'
const listingHref = getListingHref(item.slug)
const statusMeta = listingStatusMeta[item.status]
---

<article class:list={['business-card', `business-card--${variant}`]}>
  <a class="business-card__image" href={listingHref}>
    <img src={item.image} alt={`${item.name} in ${item.area}`} />
  </a>

  <div class="business-card__body">
    {!isHome && <p class="business-card__eyebrow">{item.category}</p>}

    <div class="business-card__title-row">
      <h3>
        <a href={listingHref}>{item.name}</a>
      </h3>

      <span
        class:list={['verified', `is-${item.status}`]}
        aria-label={statusMeta.ariaLabel}
        title={statusMeta.label}
      >
        <svg class="icon" aria-hidden="true">
          <use href="#i-badge" />
        </svg>
      </span>
    </div>

    {
      isHome ? (
        <p class="business-card__meta">
          <span class="business-card__category">{item.category}</span>
          <span aria-hidden="true">•</span>
          <span>{item.area}</span>
        </p>
      ) : (
        <p class="business-card__meta">
          <span>{item.area}</span>
          <span aria-hidden="true">•</span>
          <span>{item.distance}</span>
        </p>
      )
    }

    {!isHome && <p class="business-card__summary">{item.summary}</p>}

    {
      isHome ? (
        <div class:list={['business-card__verified-row', `is-${item.status}`]}>
          <span>{statusMeta.dateLabel}</span>
          <time>{item.lastChecked}</time>
        </div>
      ) : (
        <div class="business-card__status">
          <strong>Open now</strong>
          <span aria-hidden="true">•</span>
          <span>Closes {item.closes}</span>
        </div>
      )
    }
  </div>
</article>