---
type Props = {
  overlay?: boolean
}

const { overlay = true } = Astro.props
---

<header class:list={['site-header', { 'is-overlay': overlay }]}>
  <div class="wrapper">
    <a class="logo" href="/" aria-label="Shuswap Commons home">
      <span>Shuswap</span>
      <span>Commons</span>
    </a>

    <nav class="nav" aria-label="Main navigation">
      <a href="/directory">
        Directory
        <svg class="icon" aria-hidden="true">
          <use href="#i-chevron" />
        </svg>
      </a>

      <a href="/directory">Areas</a>

      <a href="/directory">
        Categories
        <svg class="icon" aria-hidden="true">
          <use href="#i-chevron" />
        </svg>
      </a>

      <a href="/">About</a>
      <a href="/">Submit</a>
    </nav>

    <div class="header-actions">
      <a class="add-btn" href="/">
        <svg class="icon" aria-hidden="true">
          <use href="#i-plus" />
        </svg>
        Add or Update
      </a>

      <a class="user-btn" href="/" aria-label="Account">
        <svg class="icon" aria-hidden="true">
          <use href="#i-user" />
        </svg>
      </a>
    </div>

    <div class="mobile-header">
      <a class="mobile-logo" href="/" aria-label="Shuswap Commons home">
        <svg class="icon tree" aria-hidden="true">
          <use href="#i-tree" />
        </svg>

        <span>Shuswap<br />Commons</span>
      </a>

      <div class="mobile-icons" aria-label="Mobile navigation actions">
        <svg class="icon" aria-hidden="true">
          <use href="#i-search" />
        </svg>

        <svg class="icon" aria-hidden="true">
          <use href="#i-menu" />
        </svg>
      </div>
    </div>
  </div>
</header>