---
import { ROUTES } from '../data/siteRoutes'

type Props = {
  overlay?: boolean
}

const { overlay = true } = Astro.props
---

<header class:list={['site-header', { 'is-overlay': overlay }]}>
  <div class="wrapper">
    <a class="logo" href={ROUTES.home} aria-label="Shuswap Commons home">
      <span>Shuswap</span>
      <span>Commons</span>
    </a>

    <nav class="nav" aria-label="Main navigation">
      <a href={ROUTES.directory}>
        Directory
        <svg class="icon" aria-hidden="true">
          <use href="#i-chevron" />
        </svg>
      </a>

      <a href={ROUTES.areas}>Areas</a>

      <a href={ROUTES.categories}>
        Categories
        <svg class="icon" aria-hidden="true">
          <use href="#i-chevron" />
        </svg>
      </a>

      <a href={ROUTES.about}>About</a>
      <a href={ROUTES.submit}>Submit</a>
    </nav>

    <div class="header-actions">
      <a class="add-btn" href={ROUTES.submit}>
        <svg class="icon" aria-hidden="true">
          <use href="#i-plus" />
        </svg>
        Add or Update
      </a>
    </div>

    <div class="mobile-header">
      <a class="mobile-logo" href={ROUTES.home} aria-label="Shuswap Commons home">
        <svg class="icon tree" aria-hidden="true">
          <use href="#i-tree" />
        </svg>

        <span>Shuswap<br />Commons</span>
      </a>

      <div class="mobile-icons" aria-label="Mobile navigation actions">
        <a href={ROUTES.directory} aria-label="Search directory">
          <svg class="icon" aria-hidden="true">
            <use href="#i-search" />
          </svg>
        </a>

        <a href={ROUTES.directory} aria-label="Browse directory">
          <svg class="icon" aria-hidden="true">
            <use href="#i-menu" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>