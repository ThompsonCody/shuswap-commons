---
import { ChevronDown, Plus, User, Search, Menu } from '@lucide/astro'

const { overlay = true } = Astro.props
---

<header class:list={['site-header', { 'site-header--overlay': overlay }]}>
  <div class="site-header__inner container">
    <a class="logo" href="/">
      <span>Shuswap</span>
      <span>Commons</span>
    </a>

    <nav class="nav desktop-only" aria-label="Main navigation">
      <a href="/directory">Directory <ChevronDown size={14} /></a>
      <a href="/directory">Areas</a>
      <a href="/directory">Categories <ChevronDown size={14} /></a>
      <a href="/">About</a>
      <a href="/">Submit</a>
    </nav>

    <div class="site-header__actions desktop-only">
      <a class="add-btn" href="/">
        <Plus size={16} />
        Add or Update
      </a>
      <button class="icon-btn" aria-label="Account">
        <User size={18} />
      </button>
    </div>

    <div class="mobile-actions mobile-only">
      <Search size={22} />
      <Menu size={26} />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: relative;
    z-index: 20;
    padding: 28px 0;
  }

  .site-header--overlay {
    position: absolute;
    inset: 0 0 auto;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .logo {
    display: grid;
    color: var(--text);
    font-size: clamp(1.55rem, 2.3vw, 2rem);
    font-weight: 900;
    letter-spacing: -0.08em;
    line-height: 0.82;
    text-decoration: none;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: clamp(24px, 4vw, 52px);
    font-size: 0.94rem;
    font-weight: 650;
  }

  .nav a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text);
    text-decoration: none;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .add-btn,
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(240, 177, 91, 0.72);
    background: rgba(10, 20, 21, 0.54);
    color: var(--amber-2);
  }

  .add-btn {
    min-height: 46px;
    gap: 10px;
    border-radius: 9px;
    padding: 0 24px;
    font-weight: 750;
    text-decoration: none;
  }

  .icon-btn {
    width: 46px;
    height: 46px;
    border-color: rgba(255,255,255,0.28);
    border-radius: 999px;
    color: var(--text);
  }

  .mobile-actions {
    display: flex;
    align-items: center;
    gap: 22px;
  }

  @media (max-width: 900px) {
    .site-header {
      padding: 26px 0;
    }

    .logo {
      font-size: 1.15rem;
      line-height: 0.86;
    }
  }
</style>