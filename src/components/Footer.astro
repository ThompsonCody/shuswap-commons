---
import { ROUTES } from '../data/siteRoutes'
---

<footer class="footer">
  <div class="wrapper footer-grid">
    <div>
      <a class="footer-logo" href={ROUTES.home} aria-label="Shuswap Commons home">
        <span>Shuswap</span>
        <span>Commons</span>
      </a>

      <p>
        A local directory and community commons for the Shuswap. Built for
        residents, visitors, and the businesses that make this place great.
      </p>

      <div class="socials" aria-label="Social links">
        <span>f</span>
        <span>◎</span>
        <span>
          <svg class="icon" aria-hidden="true">
            <use href="#i-mail" />
          </svg>
        </span>
      </div>
    </div>

    <nav class="footer-col" aria-label="Explore">
      <strong>Explore</strong>
      <a href={ROUTES.directory}>Directory</a>
      <a href={ROUTES.areas}>Areas</a>
      <a href={ROUTES.categories}>Categories</a>
      <a href={ROUTES.recentlyVerified}>Recently Verified</a>
      <a href={ROUTES.communityUpdates}>Community Updates</a>
    </nav>

    <nav class="footer-col" aria-label="About">
      <strong>About</strong>
      <a href={ROUTES.about}>About Us</a>
      <a href={ROUTES.mission}>Our Mission</a>
      <a href={ROUTES.howItWorks}>How It Works</a>
      <a href={ROUTES.contact}>Contact</a>
    </nav>

    <nav class="footer-col" aria-label="For Businesses">
      <strong>For Businesses</strong>
      <a href={ROUTES.submit}>Add or Update Listing</a>
      <a href={ROUTES.businessGuidelines}>Business Guidelines</a>
      <a href={ROUTES.whyGetListed}>Why Get Listed</a>
      <a href={ROUTES.resources}>Resources</a>
    </nav>

    <div>
      <strong>Stay in the Loop</strong>

      <p>
        Get updates on new listings, community news, and events.
      </p>

      <form class="newsletter">
        <label class="sr-only" for="footer-email">Email address</label>

        <input id="footer-email" type="email" placeholder="Your email address" />

        <button type="submit" aria-label="Submit email">
          <svg class="icon" aria-hidden="true">
            <use href="#i-arrow" />
          </svg>
        </button>
      </form>
    </div>
  </div>

  <div class="wrapper footer-bottom">
    <p>© 2026 Shuswap Commons. All rights reserved.</p>

    <div>
      <a href="/">Privacy</a>
      <a href="/">Terms</a>
      <a href="/">Accessibility</a>
    </div>
  </div>
</footer>