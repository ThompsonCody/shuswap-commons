---
type CategoryTone = 'blue' | 'green' | 'amber'

type Category = {
  name: string
  sub: string
  icon: string
  href?: string
  tone?: CategoryTone
}

type Props = {
  categories: readonly Category[]
}

const { categories } = Astro.props
---

<section class="wrapper categories" aria-label="Browse by category">
  {
    categories.map((category) => (
      <a
        class:list={[
          'category-card',
          'glass',
          category.tone ? `is-${category.tone}` : '',
        ]}
        href={category.href ?? '/directory'}
      >
        <svg class="icon cat-icon" aria-hidden="true">
          <use href={`#${category.icon}`} />
        </svg>

        <strong>{category.name}</strong>
        <span>{category.sub}</span>
      </a>
    ))
  }
</section>