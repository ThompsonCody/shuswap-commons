<section class="home-hero">
  <div class="wrapper home-hero-grid">
    <div class="hero-copy">
      <p class="kicker">Local guide. Real people. Current info.</p>

      <h1>
        Find the
        <span>good stuff</span>
        in the Shuswap.
      </h1>

      <p class="intro">
        Your curated guide to local businesses, services, and community
        resources across the Shuswap.
      </p>

      <form class="searchbar" action="/directory">
        <div class="search-placeholder">
          <svg class="icon" aria-hidden="true">
            <use href="#i-search" />
          </svg>

          <span>Search businesses, services, or keywords...</span>
        </div>

        <div class="area-select">
          <svg class="icon" aria-hidden="true">
            <use href="#i-pin" />
          </svg>

          <span>Any Area</span>

          <svg class="icon" aria-hidden="true">
            <use href="#i-chevron" />
          </svg>
        </div>

        <button type="submit">Search</button>
      </form>

      <div class="hero-actions">
        <a class="btn amber" href="/directory">
          Explore Directory

          <svg class="icon" aria-hidden="true">
            <use href="#i-arrow" />
          </svg>
        </a>

        <a class="link-arrow" href="/directory">
          Browse by Area
        </a>
      </div>
    </div>

    <div class="hero-side">
      <div class="community-card glass">
        <svg class="icon mountain" aria-hidden="true">
          <use href="#i-mountain" />
        </svg>

        <p>
          <strong>Rooted in community.</strong><br />
          Here for the long run.
        </p>
      </div>
    </div>
  </div>
</section>
