<section class="home-hero">
  <div class="wrapper home-hero-grid">
    <div class="hero-copy">
      <p class="kicker">Local guide. Real people. Current info.</p>

      <h1 class="hero-title">
        <span>Find the</span>
        <span>good stuff in</span>
        <span>the <em>Shuswap.</em></span>
      </h1>

      <p class="intro">
        Your curated guide to local businesses, services, and community
        resources across the Shuswap.
      </p>

      <form class="searchbar" action="/directory">
        <label class="search-placeholder">
          <svg class="icon" aria-hidden="true">
            <use href="#i-search" />
          </svg>

          <span>Search businesses, services, or keywords...</span>
          <input
            class="sr-only"
            type="search"
            name="q"
            aria-label="Search businesses, services, or keywords"
          />
        </label>

        <label class="area-select">
          <svg class="icon" aria-hidden="true">
            <use href="#i-pin" />
          </svg>

          <span>Any Area</span>

          <svg class="icon chevron" aria-hidden="true">
            <use href="#i-chevron" />
          </svg>

          <select class="sr-only" name="area" aria-label="Choose an area">
            <option value="">Any Area</option>
          </select>
        </label>

        <button type="submit">Search</button>
      </form>

      <div class="hero-actions">
        <a class="btn amber" href="/directory">
          Explore Directory

          <svg class="icon" aria-hidden="true">
            <use href="#i-arrow" />
          </svg>
        </a>

        <a class="link-arrow" href="/directory">
          Browse by Area

          <svg class="icon" aria-hidden="true">
            <use href="#i-arrow" />
          </svg>
        </a>
      </div>
    </div>

    <div class="hero-side">
      <div class="community-card glass">
        <svg class="icon mountain" aria-hidden="true">
          <use href="#i-mountain" />
        </svg>

        <p>
          <strong>Rooted in community.</strong>
          <span>Here for the long run.</span>
        </p>
      </div>
    </div>
  </div>
</section>
