---
const { area } = Astro.props
---

<a class="area-card" href="/directory">
  <img src="/images/area-lake.jpg" alt="" />
  <strong>{area}</strong>
</a>

<style>
  .area-card {
    position: relative;
    display: block;
    min-height: 132px;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--text);
    text-decoration: none;
  }

  .area-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent 58%);
  }

  img {
    width: 100%;
    height: 132px;
    object-fit: cover;
  }

  strong {
    position: absolute;
    z-index: 1;
    left: 16px;
    bottom: 14px;
    font-size: 1.05rem;
  }

  @media (max-width: 760px) {
    .area-card,
    img {
      min-height: 96px;
      height: 96px;
    }
  }
</style>