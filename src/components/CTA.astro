---
import { ArrowRight } from '@lucide/astro'

const { split = false } = Astro.props
---

<section class:list={['cta container', { 'cta--split': split }]}>
  {split ? (
    <>
      <div>
        <h2>Own this business?</h2>
        <p>Claim your listing to update details, add photos, respond to reviews, and more.</p>
        <a class="btn btn--amber" href="/">
          Claim This Listing
          <ArrowRight size={18} />
        </a>
      </div>
      <div>
        <h2>See something missing or not quite right?</h2>
        <p>Help keep the Shuswap Commons accurate and useful for everyone.</p>
        <a class="btn" href="/">
          Suggest an Edit
          <ArrowRight size={18} />
        </a>
      </div>
    </>
  ) : (
    <>
      <div>
        <h2>Help keep the Shuswap Commons current.</h2>
        <p>
          Know a great local business we should feature? Or see something that needs an update?
          Your input keeps our directory accurate and useful.
        </p>
      </div>
      <div class="cta__actions">
        <a class="btn btn--amber" href="/">
          Add Your Business
          <ArrowRight size={18} />
        </a>
        <a class="btn" href="/">
          Suggest an Edit
          <ArrowRight size={18} />
        </a>
      </div>
    </>
  )}
</section>

<style>
  .cta {
    display: grid;
    grid-template-columns: 1.2fr auto;
    align-items: center;
    gap: 36px;
    margin-block: 44px;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: var(--radius);
    padding: 42px 74px;
    background:
      linear-gradient(90deg, rgba(14, 38, 30, 0.72), rgba(16, 31, 31, 0.7)),
      url('/images/hero-shuswap.jpg') center/cover;
    box-shadow: var(--shadow);
  }

  .cta--split {
    grid-template-columns: 1fr 1fr;
  }

  .cta--split > div + div {
    border-left: 1px solid var(--border);
    padding-left: 66px;
  }

  h2 {
    max-width: 620px;
    margin: 0;
    font-size: clamp(1.75rem, 3vw, 2.35rem);
    letter-spacing: -0.055em;
    line-height: 1.02;
  }

  p {
    max-width: 620px;
    margin: 14px 0 0;
    color: var(--muted);
    line-height: 1.5;
  }

  .cta__actions {
    display: flex;
    gap: 18px;
  }

  .cta--split .btn {
    margin-top: 24px;
  }

  @media (max-width: 860px) {
    .cta,
    .cta--split {
      grid-template-columns: 1fr;
      padding: 28px 22px;
    }

    .cta__actions {
      flex-direction: column;
    }

    .cta--split > div + div {
      border-left: 0;
      border-top: 1px solid var(--border);
      padding-top: 28px;
      padding-left: 0;
    }
  }
</style>