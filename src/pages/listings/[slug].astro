---
import BaseLayout from '../../layouts/BaseLayout.astro'

import { listingStatusMeta, listings } from '../../data/listings'
import { getCategoryHref, getListingHref, getSubmitHref } from '../../data/siteRoutes'

export function getStaticPaths() {
  return listings.map((listing) => ({
    params: { slug: listing.slug },
    props: { listing },
  }))
}

const { listing } = Astro.props
const statusMeta = listingStatusMeta[listing.status]

const relatedCandidates = listings.filter((item) => {
  if (item.slug === listing.slug) return false
  return item.category === listing.category || item.area === listing.area
})

const related =
  relatedCandidates.length >= 3
    ? relatedCandidates.slice(0, 3)
    : listings.filter((item) => item.slug !== listing.slug).slice(0, 3)

const mapHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(listing.mapQuery)}`
const phoneHref = `tel:${listing.phone.replace(/[^\d+]/g, '')}`
const mailHref = `mailto:${listing.email}`

const socialLinks = [
  listing.socials?.instagram
    ? { label: 'Instagram', href: listing.socials.instagram }
    : null,
  listing.socials?.facebook
    ? { label: 'Facebook', href: listing.socials.facebook }
    : null,
].filter((item): item is { label: string; href: string } => Boolean(item))

const mapStyle = `background: linear-gradient(rgba(206,229,201,.5), rgba(206,229,201,.5)), url('${listing.mapImage}') center/cover;`
---

<BaseLayout
  title={`${listing.name} | Shuswap Commons`}
  description={listing.summary}
>
  <main>
    <section
      class="detail-hero"
      style={`background-image: linear-gradient(90deg, rgba(5,12,13,.98), rgba(5,12,13,.74) 34%, rgba(5,12,13,.18) 78%), linear-gradient(to bottom, rgba(5,12,13,.04), #061011 100%), url('${listing.image}')`}
    >
      <div class="wrapper">
        <div class="breadcrumbs">
          <a href="/">Home</a>
          <span>›</span>
          <a href="/directory">Directory</a>
          <span>›</span>
          <a href={getCategoryHref(listing.category)}>{listing.category}</a>
          <span>›</span>
          <span>{listing.name}</span>
        </div>

        <h1>
          {listing.name}

          <span class="verified" aria-label="Verified listing">
            <svg class="icon" aria-hidden="true">
              <use href="#i-badge" />
            </svg>
          </span>
        </h1>

        <p class="detail-meta">
          <a href={getCategoryHref(listing.category)}>{listing.category}</a>
          <span>•</span>
          {listing.area}, BC
        </p>

        <p class="detail-summary">{listing.summary}</p>

        <div class="detail-actions">
          <a class="btn amber" href={listing.website} target="_blank" rel="noreferrer">
            <svg class="icon" aria-hidden="true">
              <use href="#i-globe" />
            </svg>
            Visit Website
            <svg class="icon" aria-hidden="true">
              <use href="#i-up" />
            </svg>
          </a>

          <a class="btn" href={phoneHref}>
            <svg class="icon" aria-hidden="true">
              <use href="#i-phone" />
            </svg>
            {listing.phone}
          </a>

          <a class="btn" href={mapHref} target="_blank" rel="noreferrer">
            <svg class="icon" aria-hidden="true">
              <use href="#i-pin" />
            </svg>
            Get Directions
          </a>

          <a class="btn" href={getSubmitHref('edit', listing.slug)}>
            <svg class="icon" aria-hidden="true">
              <use href="#i-edit" />
            </svg>
            Suggest an Edit
          </a>
        </div>

        <p class="verified-line">
          <span class="verified" aria-hidden="true">
            <svg class="icon">
              <use href="#i-badge" />
            </svg>
          </span>
          <span class:list={['listing-status-label', `is-${listing.status}`]}>
            {statusMeta.label}
          </span>
          <span>
            {statusMeta.dateLabel}: <time>{listing.lastChecked}</time>
          </span>
        </p>
      </div>
    </section>

    <section class="wrapper detail-layout">
      <div class="main-col">
        <article class="panel">
          <h2>About</h2>

          {
            listing.detailAbout.map((paragraph) => (
              <p>{paragraph}</p>
            ))
          }

          <div class="feature-row">
            {
              listing.highlights.map((highlight) => (
                <span>
                  <svg class="icon" aria-hidden="true">
                    <use href={`#${highlight.icon}`} />
                  </svg>
                  {highlight.label}
                </span>
              ))
            }
          </div>
        </article>

        <div class="two-col">
          <article class="panel">
            <h2>
              <svg class="icon" aria-hidden="true">
                <use href="#i-clock" />
              </svg>
              Hours
            </h2>

            <div class="hours">
              {
                listing.hours.map((item) => (
                  <div>
                    <span>{item.day}</span>
                    <span>{item.hours}</span>
                  </div>
                ))
              }
            </div>

            <p>Seasonal hours may vary. Call ahead when timing matters.</p>
          </article>

          <article class="panel">
            <h2>Contact</h2>

            <div class="contact-list">
              <p>
                <svg class="icon" aria-hidden="true">
                  <use href="#i-phone" />
                </svg>
                <a href={phoneHref}>{listing.phone}</a>
              </p>

              <p>
                <svg class="icon" aria-hidden="true">
                  <use href="#i-mail" />
                </svg>
                <a href={mailHref}>{listing.email}</a>
              </p>

              <p>
                <svg class="icon" aria-hidden="true">
                  <use href="#i-globe" />
                </svg>
                <a href={listing.website} target="_blank" rel="noreferrer">
                  {listing.displayWebsite}
                </a>
              </p>   
              <p>
                <svg class="icon" aria-hidden="true">
                  <use href="#i-pin" />
                </svg>
                <a href={mapHref} target="_blank" rel="noreferrer">
                  {listing.address}
                </a>
              </p>
              
              {
                socialLinks.length > 0 && (
                  <div class="contact-socials" aria-label={`${listing.name} social links`}>
                    {socialLinks.map((social) => (
                      <a href={social.href} target="_blank" rel="noreferrer">
                        {social.label}
                        <svg class="icon" aria-hidden="true">
                          <use href="#i-up" />
                        </svg>
                      </a>
                    ))}
                  </div>
                )
              }

            </div>
          </article>

          <article class="panel">
            <h2>
              <svg class="icon" aria-hidden="true">
                <use href="#i-pin" />
              </svg>
              Service Area
            </h2>

            <p>{listing.serviceArea}</p>

            <a class="small-btn" href={mapHref} target="_blank" rel="noreferrer">
              View on Map
            </a>
          </article>

          <article class="panel">
            <h2>
              <svg class="icon" aria-hidden="true">
                <use href="#i-tag" />
              </svg>
              Attributes
            </h2>

            <div class="tags">
              {
                listing.attributes.map((attribute) => (
                  <span>{attribute}</span>
                ))
              }
            </div>
          </article>
        </div>
      </div>

      <aside class="side-col">
        <article class="panel">
          <h2>Location</h2>

          <div class="map-card" style={mapStyle}>
            <svg class="icon" style="width:44px;height:44px" aria-hidden="true">
              <use href="#i-pin" />
            </svg>
          </div>

          <a class="small-btn full" href={mapHref} target="_blank" rel="noreferrer">
            Open in Google Maps
            <svg class="icon" aria-hidden="true">
              <use href="#i-up" />
            </svg>
          </a>
        </article>

        <article class="panel">
          <h2>Photos</h2>

          <div class="photo-grid">
            {
              listing.gallery.map((img) => (
                <img src={img} alt={`${listing.name} photo`} />
              ))
            }
          </div>

          <a class="small-btn full" href={getSubmitHref('edit', listing.slug)}>
            View all photos ({listing.gallery.length})
            <svg class="icon" aria-hidden="true">
              <use href="#i-up" />
            </svg>
          </a>
        </article>

        <article class="panel">
          <h2>You might also like</h2>

          <div class="related">
            {
              related.map((item) => (
                <a class="mini-listing" href={getListingHref(item.slug)}>
                  <img src={item.image} alt={item.name} />

                  <div>
                    <h3>{item.name}</h3>
                    <p>{item.category} • {item.area}</p>
                  </div>

                  <span class="verified" aria-label="Verified listing">
                    <svg class="icon" aria-hidden="true">
                      <use href="#i-badge" />
                    </svg>
                  </span>
                </a>
              ))
            }
          </div>
        </article>
      </aside>
    </section>

    <section class="wrapper cta">
      <div>
        <h2>Own this business?</h2>

        <p>
          Claim your listing to update details, add photos, respond to reviews,
          and more.
        </p>
      </div>

      <div class="cta-actions">
        <a class="btn amber" href={getSubmitHref('claim', listing.slug)}>
          Claim This Listing
          <svg class="icon" aria-hidden="true">
            <use href="#i-arrow" />
          </svg>
        </a>

        <a class="btn" href={getSubmitHref('edit', listing.slug)}>
          Suggest an Edit
          <svg class="icon" aria-hidden="true">
            <use href="#i-arrow" />
          </svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>