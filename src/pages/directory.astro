---
import BaseLayout from '../layouts/BaseLayout.astro'
import ListingCard from '../components/ListingCard.astro'
import { listings } from '../data/mockListings'
import { getSubmitHref } from '../data/siteRoutes'
---
<BaseLayout
  title="Browse Businesses | Shuswap Commons"
  description="Browse trusted local businesses, services, and organizations across the Shuswap."
>

<main>
  <section class="page-hero">
    <div class="wrapper">
      <div class="breadcrumbs"><a href="/">Home</a><span>›</span><span>Directory</span></div>
      <h1>Browse Businesses</h1>
      <p>Discover trusted local businesses, services, and organizations across the Shuswap. Support local, shop local, and keep our communities thriving.</p>
    </div>
  </section>
  <section class="wrapper filter-panel glass">
    <div class="filter-row">
      <div class="fake-input"><svg class="icon"><use href="#i-search"/></svg>Search businesses, services, or keywords...</div>
      <div class="fake-select"><svg class="icon"><use href="#i-pin"/></svg>Any Area <svg class="icon"><use href="#i-chevron"/></svg></div>
      <div class="fake-select">All Categories <svg class="icon"><use href="#i-chevron"/></svg></div>
      <div class="fake-select">More Filters</div>
      <div class="fake-select">Sort: Recommended <svg class="icon"><use href="#i-chevron"/></svg></div>
    </div>
    <div class="filter-chips">
      <span class="chip active">All Results <strong>128</strong></span><span class="chip">Verified <strong>96</strong></span><span class="chip">Open Now <strong>42</strong></span><span class="chip">Offers Online Booking <strong>28</strong></span>
      <a class="clear-filter" href="/directory">Clear all filters</a>
    </div>
  </section>
  <section class="wrapper">
    <div class="results-head"><span>Showing 1–12 of 128 results</span><div class="toggle"><span>Grid</span><span>Map</span></div></div>
    <div class="directory-grid">
      {
        listings.map((item) => (
          <ListingCard item={item} variant="directory" />
        ))
      }
    </div> 
  </section>
  <section class="wrapper cta">
    <div>
      <h2>Help keep the Shuswap Commons current.</h2>
      <p>Know a great local business we should feature? Or see something that needs an update?</p>
    </div>

    <div class="cta-actions">
      <a class="btn amber" href={getSubmitHref('add')}>
        Add Your Business
        <svg class="icon" aria-hidden="true">
          <use href="#i-arrow" />
        </svg>
      </a>

      <a class="btn" href={getSubmitHref('edit')}>
        Suggest an Edit
        <svg class="icon" aria-hidden="true">
          <use href="#i-arrow" />
        </svg>
      </a>
    </div>
  </section>
</main>

</BaseLayout>
