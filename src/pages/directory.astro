---
import '../styles/global.css'
import ListingCard from '../components/ListingCard.astro'
import { listings } from '../data/mockListings'
---
<html lang="en">
<head><meta charset="utf-8" /><meta name="viewport" content="width=device-width" /><title>Directory | Shuswap Commons</title></head>
<body>

<!-- Inline icon sprite: avoids dependency/import failures -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
  <symbol id="i-search" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></symbol>
  <symbol id="i-pin" viewBox="0 0 24 24"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/></symbol>
  <symbol id="i-chevron" viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"/></symbol>
  <symbol id="i-plus" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></symbol>
  <symbol id="i-user" viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></symbol>
  <symbol id="i-menu" viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h16"/></symbol>
  <symbol id="i-arrow" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></symbol>
  <symbol id="i-up" viewBox="0 0 24 24"><path d="M7 17 17 7M7 7h10v10"/></symbol>
  <symbol id="i-badge" viewBox="0 0 24 24"><path d="M7.5 4.2 12 2l4.5 2.2 5 1.4-1.4 5L22 15l-4.2 3.1L15 22l-3-2-3 2-2.8-3.9L2 15l1.9-4.4-1.4-5 5-1.4Z"/><path d="m8.5 12 2.2 2.2 4.8-5"/></symbol>
  <symbol id="i-mountain" viewBox="0 0 24 24"><path d="m3 20 7-14 4 8 2-4 5 10H3Z"/></symbol>
  <symbol id="i-tree" viewBox="0 0 24 24"><path d="M12 22V9"/><path d="m9 9 3-7 3 7"/><path d="m7 15 5-6 5 6"/><path d="m5 20 7-8 7 8"/></symbol>
  <symbol id="i-food" viewBox="0 0 24 24"><path d="M4 3v8"/><path d="M8 3v8"/><path d="M4 7h4"/><path d="M6 11v10"/><path d="M15 3v18"/><path d="M19 3c0 5-4 5-4 5"/></symbol>
  <symbol id="i-tool" viewBox="0 0 24 24"><path d="m14 6 4 4"/><path d="M11 9 4 16v4h4l7-7"/><path d="M20 8 16 4l2-2 4 4-2 2Z"/></symbol>
  <symbol id="i-bag" viewBox="0 0 24 24"><path d="M6 8h12l-1 12H7L6 8Z"/><path d="M9 8a3 3 0 0 1 6 0"/></symbol>
  <symbol id="i-leaf" viewBox="0 0 24 24"><path d="M20 4c-9 0-15 5-15 14 9 0 15-5 15-14Z"/><path d="M5 18c4-4 8-6 15-14"/></symbol>
  <symbol id="i-briefcase" viewBox="0 0 24 24"><path d="M10 6V5a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v1"/><rect x="3" y="6" width="18" height="14" rx="2"/><path d="M3 12h18"/></symbol>
  <symbol id="i-users" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-8 0v2"/><circle cx="12" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M2 21v-2a4 4 0 0 1 3-3.87"/></symbol>
  <symbol id="i-bed" viewBox="0 0 24 24"><path d="M3 7v14"/><path d="M21 12v9"/><path d="M3 15h18"/><path d="M7 12h10a4 4 0 0 1 4 4"/></symbol>
  <symbol id="i-star" viewBox="0 0 24 24"><path d="m12 2 3 7 7 .6-5.3 4.8 1.6 7-6.3-3.7-6.3 3.7 1.6-7L2 9.6 9 9l3-7Z"/></symbol>
  <symbol id="i-refresh" viewBox="0 0 24 24"><path d="M21 12a9 9 0 0 1-15.5 6.2"/><path d="M3 12A9 9 0 0 1 18.5 5.8"/><path d="M18 2v5h-5"/><path d="M6 22v-5h5"/></symbol>
  <symbol id="i-clock" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></symbol>
  <symbol id="i-globe" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 0 20"/><path d="M12 2a15.3 15.3 0 0 0 0 20"/></symbol>
  <symbol id="i-phone" viewBox="0 0 24 24"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.4 19.4 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.8a2 2 0 0 1-.4 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.8.6 2.8.7A2 2 0 0 1 22 16.9Z"/></symbol>
  <symbol id="i-mail" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></symbol>
  <symbol id="i-edit" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5Z"/></symbol>
  <symbol id="i-tag" viewBox="0 0 24 24"><path d="M20 10 12 2H4v8l8 8 8-8Z"/><circle cx="7.5" cy="7.5" r="1"/></symbol>
  <symbol id="i-map" viewBox="0 0 24 24"><path d="M9 18 3 21V6l6-3 6 3 6-3v15l-6 3-6-3Z"/><path d="M9 3v15M15 6v15"/></symbol>
</svg>


<header class="site-header">
  <div class="wrapper">
    <a class="logo" href="/"><span>Shuswap</span><span>Commons</span></a>

    <nav class="nav" aria-label="Main navigation">
      <a href="/directory">Directory <svg class="icon"><use href="#i-chevron" /></svg></a>
      <a href="/directory">Areas</a>
      <a href="/directory">Categories <svg class="icon"><use href="#i-chevron" /></svg></a>
      <a href="/">About</a>
      <a href="/">Submit</a>
    </nav>

    <div class="header-actions">
      <a class="add-btn" href="/"><svg class="icon"><use href="#i-plus" /></svg>Add or Update</a>
      <a class="user-btn" href="/" aria-label="Account"><svg class="icon"><use href="#i-user" /></svg></a>
    </div>

    <div class="mobile-header">
      <a class="mobile-logo" href="/">
        <svg class="icon tree"><use href="#i-tree" /></svg>
        <span>Shuswap<br />Commons</span>
      </a>
      <div class="mobile-icons">
        <svg class="icon"><use href="#i-search" /></svg>
        <svg class="icon"><use href="#i-menu" /></svg>
      </div>
    </div>
  </div>
</header>

<main>
  <section class="page-hero">
    <div class="wrapper">
      <div class="breadcrumbs"><a href="/">Home</a><span>›</span><span>Directory</span></div>
      <h1>Browse Businesses</h1>
      <p>Discover trusted local businesses, services, and organizations across the Shuswap. Support local, shop local, and keep our communities thriving.</p>
    </div>
  </section>
  <section class="wrapper filter-panel glass">
    <div class="filter-row">
      <div class="fake-input"><svg class="icon"><use href="#i-search"/></svg>Search businesses, services, or keywords...</div>
      <div class="fake-select"><svg class="icon"><use href="#i-pin"/></svg>Any Area <svg class="icon"><use href="#i-chevron"/></svg></div>
      <div class="fake-select">All Categories <svg class="icon"><use href="#i-chevron"/></svg></div>
      <div class="fake-select">More Filters</div>
      <div class="fake-select">Sort: Recommended <svg class="icon"><use href="#i-chevron"/></svg></div>
    </div>
    <div class="filter-chips">
      <span class="chip active">All Results <strong>128</strong></span><span class="chip">Verified <strong>96</strong></span><span class="chip">Open Now <strong>42</strong></span><span class="chip">Offers Online Booking <strong>28</strong></span>
      <a class="clear-filter" href="/">Clear all filters</a>
    </div>
  </section>
  <section class="wrapper">
    <div class="results-head"><span>Showing 1–12 of 128 results</span><div class="toggle"><span>Grid</span><span>Map</span></div></div>
    <div class="directory-grid">{listings.map((item) => <ListingCard item={item} />)}</div>
  </section>
  <section class="wrapper cta">
    <div><h2>Help keep the Shuswap Commons current.</h2><p>Know a great local business we should feature? Or see something that needs an update?</p></div>
    <div class="cta-actions"><a class="btn amber" href="/">Add Your Business <svg class="icon"><use href="#i-arrow" /></svg></a><a class="btn" href="/">Suggest an Edit <svg class="icon"><use href="#i-arrow" /></svg></a></div>
  </section>
</main>

<footer class="footer">
  <div class="wrapper footer-grid">
    <div>
      <a class="footer-logo" href="/"><span>Shuswap</span><span>Commons</span></a>
      <p>A local directory and community commons for the Shuswap. Built for residents, visitors, and the businesses that make this place great.</p>
      <div class="socials"><span>f</span><span>◎</span><span><svg class="icon"><use href="#i-mail" /></svg></span></div>
    </div>

    <div class="footer-col"><strong>Explore</strong><a href="/directory">Directory</a><a href="/directory">Areas</a><a href="/directory">Categories</a><a href="/directory">Recently Verified</a><a href="/">Community Updates</a></div>
    <div class="footer-col"><strong>About</strong><a href="/">About Us</a><a href="/">Our Mission</a><a href="/">How It Works</a><a href="/">Contact</a></div>
    <div class="footer-col"><strong>For Businesses</strong><a href="/">Add or Update Listing</a><a href="/">Business Guidelines</a><a href="/">Why Get Listed</a><a href="/">Resources</a></div>
    <div class="footer-col">
      <strong>Stay in the Loop</strong>
      <p>Get updates on new listings, community news, and events.</p>
      <form class="newsletter"><input placeholder="Your email address" /><button aria-label="Subscribe"><svg class="icon"><use href="#i-arrow" /></svg></button></form>
    </div>
  </div>

  <div class="wrapper footer-bottom">
    <span>© 2026 Shuswap Commons. All rights reserved.</span>
    <div><a href="/">Privacy</a><a href="/">Terms</a><a href="/">Accessibility</a></div>
  </div>
</footer>

</body>
</html>
